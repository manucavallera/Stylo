    {
      "parameters": {
        "jsCode": "const remoteJid = $('Parsear Mensaje').first().json.remoteJid;\nconst cat = $json.prenda?.categoria?.nombre || 'Prenda';\nconst talle = $json.prenda?.talle?.nombre || '';\nconst desc = cat + (talle ? ` — Talle ${talle}` : '');\nreturn [{ json: { remoteJid, mensaje: `🎉 ¡Listo! Recibimos tu comprobante y confirmamos la venta de *${desc}*. ¡Gracias por tu compra! 🛍️` } }];"
      },
