{
  "name": "Gabi - Bot Reservas WhatsApp",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mensajes-entrantes",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "c1b2c3d4-0001-0001-0001-000000000001",
      "name": "Webhook Mensajes",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 400],
      "webhookId": "c1b2c3d4-0001-0001-0001-000000000001"
    },
    {
      "parameters": {
        "jsCode": "// Parsear webhook de Evolution API\n// En n8n webhook v2 el body llega en $json.body\nconst body = $json.body || $json;\nconst data = body.data || body;\n\n// Ignorar mensajes propios\nif (data.key?.fromMe === true) return [];\n\n// Solo chats privados (no grupos)\nconst remoteJid = data.key?.remoteJid || '';\nif (!remoteJid || remoteJid.endsWith('@g.us') || remoteJid.endsWith('@broadcast')) return [];\n\nconst message = data.message || {};\nconst caption =\n  message.imageMessage?.caption ||\n  message.extendedTextMessage?.text ||\n  message.conversation || '';\n\nconst telefono = remoteJid.replace('@s.whatsapp.net', '');\nconst nombreCliente = data.pushName || null;\n\n// Caso 1: tiene código invisible → reservar\nconst match = caption.match(/\\u200B([a-f0-9]{8})/) || caption.match(/reservar\\s+([a-f0-9]{8})/i);\nif (match) {\n  return [{ json: { tipo: 'reservar', prendaId: match[1], telefono, remoteJid, nombreCliente } }];\n}\n\n// Caso 2: es una imagen sin código → intento de confirmación de pago\nconst mediaUrl = message.imageMessage?.url || message.imageMessage?.jpegThumbnail || null;\nif (message.imageMessage) {\n  return [{ json: { tipo: 'confirmar', telefono, remoteJid, mediaUrl } }];\n}\n\n// Cualquier otro mensaje: ignorar\nreturn [];"
      },
      "id": "c1b2c3d4-0002-0002-0002-000000000001",
      "name": "Parsear Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-tipo",
              "leftValue": "={{ $json.tipo }}",
              "rightValue": "reservar",
              "operator": { "type": "string", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c1b2c3d4-0009-0009-0009-000000000001",
      "name": "¿Reservar o Confirmar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 400]
    },
