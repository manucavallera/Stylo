    {
      "parameters": {
        "jsCode": "// Parsear webhook de Evolution API\nconst body = $json.body || $json;\nconst data = body.data || body;\n\n// Ignorar mensajes propios\nif (data.key?.fromMe === true) return [];\n\n// Solo chats privados (no grupos)\nconst remoteJid = data.key?.remoteJid || '';\nif (!remoteJid || remoteJid.endsWith('@g.us') || remoteJid.endsWith('@broadcast')) return [];\n\nconst message = data.message || {};\nconst caption =\n  message.imageMessage?.caption ||\n  message.extendedTextMessage?.text ||\n  message.conversation || '';\n\nconst telefono = remoteJid.replace('@s.whatsapp.net', '');\nconst nombreCliente = data.pushName || null;\n\n// Decodificar código invisible (\\u200B=0, \\u200C=1, 4 bits por hex char)\nfunction decodeInvisible(text) {\n  const zwChars = [...text].filter(c => c === '\\u200B' || c === '\\u200C');\n  if (zwChars.length < 32) return null;\n  const bits = zwChars.slice(0, 32).map(c => c === '\\u200B' ? '0' : '1').join('');\n  let hex = '';\n  for (let i = 0; i < 32; i += 4) hex += parseInt(bits.slice(i, i + 4), 2).toString(16);\n  return hex;\n}\n\nconst staticData = $getWorkflowStaticData('global');\n\n// Caso 1: imagen con código invisible → preguntar si quiere reservar\nconst prendaId = decodeInvisible(caption);\nif (prendaId) {\n  staticData[`pending_${telefono}`] = { prendaId, ts: Date.now() };\n  return [{ json: { tipo: 'pre_reservar', telefono, remoteJid, nombreCliente } }];\n}\n\n// Caso 2: texto SI → confirmar reserva pendiente\nconst textoNorm = caption.trim().toUpperCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\nif (textoNorm === 'SI') {\n  const pending = staticData[`pending_${telefono}`];\n  if (pending && (Date.now() - pending.ts) < 10 * 60 * 1000) {\n    delete staticData[`pending_${telefono}`];\n    return [{ json: { tipo: 'reservar', prendaId: pending.prendaId, telefono, remoteJid, nombreCliente } }];\n  }\n  return [];\n}\n\n// Caso 3: imagen sin código → comprobante de pago\nif (message.imageMessage) {\n  const mediaUrl = message.imageMessage?.url || null;\n  return [{ json: { tipo: 'comprobante', telefono, remoteJid, mediaUrl } }];\n}\n\n// Cualquier otro mensaje: ignorar\nreturn [];"
      },
