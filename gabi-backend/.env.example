# Variables de Entorno — Gabi Backend
# Copiá este archivo como .env y completá los valores

# ─────────────────────────────────────────
# BASE DE DATOS (Supabase)
# ─────────────────────────────────────────
# Encontrás estas URLs en: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─────────────────────────────────────────
# SUPABASE (para Storage y Auth)
# ─────────────────────────────────────────
# Encontrás estas keys en: Supabase Dashboard > Settings > API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"  # usa la service role, no la anon

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ─────────────────────────────────────────
# N8N (automatización WhatsApp)
# ─────────────────────────────────────────
N8N_WEBHOOK_URL="https://[N8N-URL]/webhook"
